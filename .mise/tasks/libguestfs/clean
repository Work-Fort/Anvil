#!/usr/bin/env bash
# SPDX-License-Identifier: Apache-2.0
#MISE description="Remove vendored libguestfs bindings"
set -euo pipefail

LIBGUESTFS_VENDOR_DIR="${LIBGUESTFS_VENDOR_DIR:-third_party/libguestfs.org/guestfs}"

if [ -d "$LIBGUESTFS_VENDOR_DIR" ]; then
  echo "Removing vendored bindings at $LIBGUESTFS_VENDOR_DIR..."
  rm -rf "$LIBGUESTFS_VENDOR_DIR"
  echo "✓ Vendored bindings removed"
else
  echo "No vendored bindings found at $LIBGUESTFS_VENDOR_DIR"
fi
